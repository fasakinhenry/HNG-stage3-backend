NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/insighta?retryWrites=true&w=majority

# ─── GitHub OAuth Configuration ───────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/auth/github/callback

# For production, use your deployed backend URL:
# GITHUB_OAUTH_CALLBACK_URL=https://your-backend-url.com/auth/github/callback

# --- JWT (generate random strings for production) ---
# Use: openssl rand -hex 32
JWT_ACCESS_SECRET=dev-access-secret-change-in-prod
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod
# TRD: 3 minutes / 5 minutes (do not change)
ACCESS_TOKEN_TTL=3m
REFRESH_TOKEN_TTL=5m

# --- Web portal (CORS + cookie config) ---
WEB_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# For production:
# WEB_ORIGIN=https://your-web-portal.com
# COOKIE_DOMAIN=your-domain.com
# COOKIE_SECURE=true

# --- CSRF ---
# Use: openssl rand -hex 32
CSRF_SECRET=dev-csrf-secret-change-in-prod

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
AUTH_RATE_LIMIT_MAX=10

# --- Bootstrap admin (first user with this GitHub username becomes admin) ---
ADMIN_GITHUB_USERNAME=fasakinhenry
